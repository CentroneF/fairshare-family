---
interface Props {
  familyName: string;
  children: readonly { id: string; name: string }[];
  joinCode: string;
  serverError?: string | null;
}

const { familyName, children, joinCode, serverError } = Astro.props;
---

<section class="space-y-6">
  <div>
    <p class="text-sm tracking-wide text-purple-200 uppercase">Your family</p>
    <h1 class="mt-1 text-3xl font-bold">{familyName}</h1>
    <p class="mt-2 text-blue-100/70">Add children now or invite the second parent first.</p>
  </div>

  <div class="rounded-xl border border-purple-300/30 bg-purple-500/15 p-4">
    <p class="text-sm font-medium text-purple-100">Share this family code</p>
    <div class="mt-2 flex items-center gap-3">
      <code id="family-join-code" class="rounded-lg bg-slate-950/40 px-3 py-2 font-mono text-lg tracking-widest"
        >{joinCode}</code
      >
      <button id="copy-family-code" type="button" class="rounded-lg p-2 hover:bg-white/10">Copy</button>
    </div>
    <p id="copy-status" class="mt-2 text-sm text-purple-100" aria-live="polite"></p>
    <form method="POST" action="/api/family/regenerate-code" class="mt-3">
      <button type="submit" class="text-sm text-purple-200 hover:text-white">Regenerate code</button>
    </form>
  </div>

  <form method="POST" action="/api/family/children" class="space-y-3">
    <div>
      <h2 class="text-lg font-semibold">Children</h2>
      {
        children.length > 0 && (
          <ul class="mt-2 space-y-1 text-sm text-blue-100/80">
            {children.map((child) => (
              <li>{child.name}</li>
            ))}
          </ul>
        )
      }
    </div>
    <div id="child-name-fields" class="space-y-2">
      <input
        name="name"
        required
        placeholder="Child name"
        class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:ring-2 focus:ring-purple-400 focus:outline-none"
      />
    </div>
    <button id="add-child-field" type="button" class="text-sm text-purple-200 hover:text-white"
      >Add another child</button
    >
    {
      serverError && (
        <p class="text-sm text-red-200" role="alert">
          {serverError}
        </p>
      )
    }
    <button type="submit" class="w-full rounded-lg bg-purple-600 px-4 py-2 font-medium hover:bg-purple-500"
      >Save children</button
    >
  </form>
</section>

<script>
  const code = document.querySelector<HTMLCodeElement>("#family-join-code");
  const copyButton = document.querySelector<HTMLButtonElement>("#copy-family-code");
  const copyStatus = document.querySelector<HTMLParagraphElement>("#copy-status");
  const fields = document.querySelector<HTMLDivElement>("#child-name-fields");
  const addChildButton = document.querySelector<HTMLButtonElement>("#add-child-field");

  const childInputClass =
    "min-w-0 flex-1 rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/40 focus:ring-2 focus:ring-purple-400 focus:outline-none";

  copyButton?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(code?.textContent ?? "");
      if (copyStatus) copyStatus.textContent = "Family code copied.";
    } catch {
      if (copyStatus) copyStatus.textContent = "Copy the family code manually.";
    }
  });

  addChildButton?.addEventListener("click", () => {
    const row = document.createElement("div");
    row.className = "flex gap-2";

    const input = document.createElement("input");
    input.name = "name";
    input.required = true;
    input.placeholder = "Child name";
    input.className = childInputClass;

    const removeButton = document.createElement("button");
    removeButton.type = "button";
    removeButton.className = "rounded-lg px-3 text-sm text-red-200 hover:bg-red-500/15";
    removeButton.textContent = "Remove";
    removeButton.setAttribute("aria-label", "Remove unsaved child");
    removeButton.addEventListener("click", () => {
      row.remove();
      addChildButton?.focus();
    });

    row.append(input, removeButton);
    fields?.append(row);
    input.focus();
  });
</script>
