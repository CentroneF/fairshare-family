---
interface Props {
  familyName: string;
  children: readonly { id: string; name: string }[];
}

const { familyName, children } = Astro.props;
---

<section>
  <p class="text-sm tracking-wide text-purple-200 uppercase">Shared family</p>
  <h1 class="mt-1 text-3xl font-bold">{familyName}</h1>
  <p class="mt-2 text-blue-100/70">Both parents now share this family.</p>
  <div class="mt-6 rounded-xl border border-white/15 bg-white/5 p-4">
    <h2 class="font-semibold">Children</h2>
    {
      children.length > 0 ? (
        <ul class="mt-3 space-y-1 text-sm text-blue-100/80">
          {children.map((child) => (
            <li>{child.name}</li>
          ))}
        </ul>
      ) : (
        <p class="mt-2 text-sm text-blue-100/60">No children added yet.</p>
      )
    }
  </div>
</section>
