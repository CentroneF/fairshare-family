---
interface Props {
  children: readonly { id: string; name: string }[];
  month: string;
  maxDate: string;
  defaultDate: string;
  serverError?: string | null;
}

const { children, month, maxDate, defaultDate, serverError } = Astro.props;
---

<form
  id="create-expense-form"
  method="POST"
  action="/api/expenses/create"
  class="grid gap-3 rounded-xl border border-white/15 bg-white/5 p-4 sm:grid-cols-2"
>
  <input type="hidden" name="month" value={month} />
  <label class="sm:col-span-2">
    <span class="mb-1 block text-sm text-blue-100/80">Description</span>
    <input
      name="description"
      required
      class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2"
      placeholder="e.g. School supplies"
    />
  </label>
  <label>
    <span class="mb-1 block text-sm text-blue-100/80">Child</span>
    <select name="childId" class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2">
      <option value="">No specific child</option>
      {children.map((child) => <option value={child.id}>{child.name}</option>)}
    </select>
  </label>
  <label>
    <span class="mb-1 block text-sm text-blue-100/80">Amount (PLN)</span>
    <input
      name="amount"
      inputmode="decimal"
      required
      class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2"
      placeholder="12,50"
    />
  </label>
  <label>
    <span class="mb-1 block text-sm text-blue-100/80">Expense date</span>
    <input
      name="expenseDate"
      type="date"
      max={maxDate}
      value={defaultDate}
      required
      class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2"
    />
  </label>
  <div class="flex items-end">
    <button
      id="create-expense-submit"
      type="submit"
      class="w-full rounded-lg bg-purple-600 px-4 py-2 font-medium hover:bg-purple-500 disabled:cursor-wait disabled:opacity-70"
      >Add expense</button
    >
  </div>
  {
    serverError && (
      <p class="sm:col-span-2" role="alert">
        {serverError}
      </p>
    )
  }
</form>

<script>
  const form = document.querySelector<HTMLFormElement>("#create-expense-form");
  const submitButton = document.querySelector<HTMLButtonElement>("#create-expense-submit");

  function showError(message: string) {
    const existing = form?.querySelector<HTMLElement>("[role='alert']");
    if (existing) {
      existing.textContent = message;
      return;
    }
    const error = document.createElement("p");
    error.className = "sm:col-span-2 text-sm text-red-200";
    error.setAttribute("role", "alert");
    error.textContent = message;
    form?.append(error);
  }

  function appendExpense(data: FormData) {
    const emptyState = document.querySelector<HTMLElement>("#empty-expense-list");
    const list = document.querySelector<HTMLUListElement>("#expense-list");
    if (!list) return;

    emptyState?.remove();
    const child = form?.querySelector<HTMLSelectElement>("[name='childId']");
    const selectedChild = child?.selectedOptions.item(0)?.textContent?.trim() || "No specific child";
    const amount = String(data.get("amount") ?? "")
      .trim()
      .replace(",", ".");
    const formattedAmount = Number(amount).toFixed(2);
    const item = document.createElement("li");
    item.className = "rounded-xl border border-white/15 bg-white/5 p-4";
    const row = document.createElement("div");
    row.className = "flex items-start justify-between gap-4";
    const details = document.createElement("div");
    const description = document.createElement("p");
    description.className = "font-medium";
    description.textContent = String(data.get("description") ?? "").trim();
    const metadata = document.createElement("p");
    metadata.className = "mt-1 text-sm text-blue-100/70";
    metadata.textContent = `${String(data.get("expenseDate") ?? "")} · ${selectedChild}`;
    details.append(description, metadata);
    const summary = document.createElement("div");
    summary.className = "text-right";
    const amountText = document.createElement("p");
    amountText.className = "font-semibold";
    amountText.textContent = `${formattedAmount} PLN`;
    const status = document.createElement("p");
    status.className = "mt-1 text-sm text-amber-200";
    status.textContent = "Awaiting review";
    summary.append(amountText, status);
    row.append(details, summary);
    item.append(row);
    list.prepend(item);
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!form || !submitButton) return;

    const data = new FormData(form);
    submitButton.disabled = true;
    submitButton.textContent = "Saving…";
    form.querySelector("[role='alert']")?.remove();

    try {
      const response = await fetch(form.action, {
        method: "POST",
        headers: { Accept: "application/json" },
        body: data,
      });
      const result = (await response.json()) as { error?: string; month?: string };
      if (!response.ok || result.error) {
        showError(result.error ?? "We could not save that expense. Please try again.");
        return;
      }
      if (result.month !== data.get("month")) {
        window.location.assign(`/dashboard?month=${result.month ?? ""}&success=expense-created`);
        return;
      }
      appendExpense(data);
      form.reset();
    } catch {
      showError("We could not save that expense. Please try again.");
    } finally {
      submitButton.disabled = false;
      submitButton.textContent = "Add expense";
    }
  });
</script>
