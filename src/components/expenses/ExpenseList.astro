---
import type { ExpenseDisplay } from "@/lib/expense-balance";

interface Props {
  expenses: readonly ExpenseDisplay[];
}

const { expenses } = Astro.props;
---

<section class="mt-6">
  <h2 class="text-lg font-semibold">Expenses</h2>
  <ul id="expense-list" class="mt-3 space-y-3">
    {
      expenses.map((expense) => (
        <li class="rounded-xl border border-white/15 bg-white/5 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-medium">{expense.description}</p>
              <p class="mt-1 text-sm text-blue-100/70">
                {expense.expenseDate} · {expense.childName ?? "No specific child"}
              </p>
            </div>
            <div class="text-right">
              <p class="font-semibold">{expense.amountPln} PLN</p>
              <p class="mt-1 text-sm text-amber-200">Awaiting review</p>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
  {
    expenses.length === 0 && (
      <p id="empty-expense-list" class="mt-2 text-sm text-blue-100/60">
        No expenses for this month yet.
      </p>
    )
  }
</section>
