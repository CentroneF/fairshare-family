---
import type { ExpenseDisplay } from "@/lib/expense-balance";

interface Props {
  expenses: readonly ExpenseDisplay[];
  month: string;
  currentMembershipId: string | null;
  canApprove: boolean;
}

const { expenses, month, currentMembershipId, canApprove } = Astro.props;
---

<section class="mt-6">
  <h2 class="text-lg font-semibold">Expenses</h2>
  <ul id="expense-list" class="mt-3 space-y-3">
    {
      expenses.map((expense) => (
        <li data-expense-id={expense.id} class="rounded-xl border border-white/15 bg-white/5 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-medium">{expense.description}</p>
              <p class="mt-1 text-sm text-blue-100/70">
                {expense.expenseDate} · {expense.childName ?? "No specific child"}
              </p>
            </div>
            <div class="text-right">
              <p class="font-semibold">{expense.amountPln} PLN</p>
              {expense.status === "approved" ? (
                <p class="mt-1 text-sm text-emerald-200">Approved</p>
              ) : canApprove && currentMembershipId && expense.payerId !== currentMembershipId ? (
                <form data-approve-expense method="POST" action="/api/expenses/approve" class="mt-2">
                  <input type="hidden" name="expenseId" value={expense.id} />
                  <input type="hidden" name="month" value={month} />
                  <button
                    type="submit"
                    class="rounded-lg bg-emerald-600 px-3 py-1 text-sm font-medium hover:bg-emerald-500"
                  >
                    Approve
                  </button>
                </form>
              ) : (
                <p class="mt-1 text-sm text-amber-200">Awaiting review</p>
              )}
            </div>
          </div>
        </li>
      ))
    }
  </ul>
  {
    expenses.length === 0 && (
      <p id="empty-expense-list" class="mt-2 text-sm text-blue-100/60">
        No expenses for this month yet.
      </p>
    )
  }
</section>

<script>
  interface ApprovalResult {
    error?: string;
    expenseId?: string;
    month?: string;
    balance?: {
      totalAmount: string;
      approvedAmount: string;
      toReviewAmount: string;
      settlement:
        | { kind: "balanced"; amount: string }
        | { kind: "payment"; amount: string; fromParentId: string; toParentId: string };
    };
  }

  function setText(selector: string, value: string) {
    const element = document.querySelector<HTMLElement>(selector);
    if (element) element.textContent = value;
  }

  function updateBalance(balance: NonNullable<ApprovalResult["balance"]>) {
    const panel = document.querySelector<HTMLElement>("[data-monthly-balance]");
    if (!panel) return;

    setText("[data-balance-total]", `${balance.totalAmount} PLN`);
    setText("[data-balance-approved]", `${balance.approvedAmount} PLN`);
    setText("[data-balance-to-review]", `${balance.toReviewAmount} PLN`);

    const hasPendingExpenses = balance.toReviewAmount !== "0.00";
    const heading = panel.querySelector<HTMLElement>("[data-balance-heading]");
    const guidance = panel.querySelector<HTMLElement>("[data-balance-guidance]");
    panel.classList.toggle("border-amber-300/30", hasPendingExpenses);
    panel.classList.toggle("bg-amber-500/10", hasPendingExpenses);
    panel.classList.toggle("border-emerald-300/30", !hasPendingExpenses);
    panel.classList.toggle("bg-emerald-500/10", !hasPendingExpenses);
    heading?.classList.toggle("text-amber-100", hasPendingExpenses);
    heading?.classList.toggle("text-emerald-100", !hasPendingExpenses);

    if (!guidance) return;
    if (hasPendingExpenses) {
      guidance.className = "mt-4 text-sm text-amber-100/80";
      guidance.textContent = "Some expenses are still awaiting review.";
      return;
    }

    const currentMembershipId = panel.dataset.currentMembershipId;
    guidance.className = "mt-4 font-medium text-emerald-100";
    guidance.textContent =
      balance.settlement.kind === "balanced"
        ? "Your approved balance is even."
        : balance.settlement.fromParentId === currentMembershipId
          ? `You owe ${balance.settlement.amount} PLN.`
          : `You are owed ${balance.settlement.amount} PLN.`;
  }

  function showApprovalError(form: HTMLFormElement, message: string) {
    const existing = form.querySelector<HTMLElement>("[role='alert']");
    if (existing) {
      existing.textContent = message;
      return;
    }
    const error = document.createElement("p");
    error.className = "mt-2 text-sm text-red-200";
    error.setAttribute("role", "alert");
    error.textContent = message;
    form.append(error);
  }

  document.querySelectorAll<HTMLFormElement>("[data-approve-expense]").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const button = form.querySelector<HTMLButtonElement>("button[type='submit']");
      const data = new FormData(form);
      button?.setAttribute("disabled", "true");
      if (button) button.textContent = "Approving…";
      form.querySelector("[role='alert']")?.remove();

      try {
        const response = await fetch(form.action, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: data,
        });
        const result = (await response.json()) as ApprovalResult;
        if (!response.ok || result.error || !result.expenseId || !result.balance) {
          showApprovalError(form, result.error ?? "We could not approve that expense. Please try again.");
          return;
        }

        const item = document.querySelector<HTMLElement>(`[data-expense-id='${result.expenseId}']`);
        const status = document.createElement("p");
        status.className = "mt-1 text-sm text-emerald-200";
        status.textContent = "Approved";
        form.replaceWith(status);
        item?.setAttribute("data-expense-status", "approved");
        updateBalance(result.balance);
      } catch {
        showApprovalError(form, "We could not approve that expense. Please try again.");
      } finally {
        button?.removeAttribute("disabled");
        if (button) button.textContent = "Approve";
      }
    });
  });
</script>
