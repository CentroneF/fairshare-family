---
import Layout from "@/layouts/Layout.astro";
import { resolveOnboardingState } from "@/lib/family-onboarding";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const onboarding = supabase && user ? await resolveOnboardingState(supabase, user.id) : { kind: "no-family" as const };
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-blue-100/80">
        Welcome, <span class="font-semibold text-white">{user?.email}</span>
      </p>
      {
        onboarding.kind === "no-family" ? (
          <p class="mt-2 text-sm text-blue-100/50">Create or join a family to get started.</p>
        ) : onboarding.kind === "creator-awaiting-parent" ? (
          <p class="mt-2 text-sm text-blue-100/50">Waiting for the second parent to join {onboarding.family.name}.</p>
        ) : (
          <p class="mt-2 text-sm text-blue-100/50">You belong to {onboarding.family.name}.</p>
        )
      }
      <form method="POST" action="/api/auth/signout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
