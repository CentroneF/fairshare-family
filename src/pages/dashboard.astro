---
import CreateFamilyForm from "@/components/family/CreateFamilyForm";
import FamilySetupPanel from "@/components/family/FamilySetupPanel.astro";
import FamilySummaryPanel from "@/components/family/FamilySummaryPanel.astro";
import JoinFamilyForm from "@/components/family/JoinFamilyForm";
import ExpenseWorkspace from "@/components/expenses/ExpenseWorkspace.astro";
import Layout from "@/layouts/Layout.astro";
import { normalizeSelectedMonth } from "@/lib/expense-balance";
import { resolveOnboardingState } from "@/lib/family-onboarding";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);
const onboarding = supabase && user ? await resolveOnboardingState(supabase, user.id) : { kind: "no-family" as const };
const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
const successMessage =
  success === "expense-approved"
    ? "Expense approved. The monthly balance was updated."
    : success === "expense-declined"
      ? "Expense declined. It no longer affects the monthly balance."
      : success === "expense-created"
        ? "Expense created and awaiting review."
        : success
          ? "Your family update was saved."
          : null;
let selectedMonth: string;
try {
  selectedMonth = normalizeSelectedMonth(Astro.url.searchParams.get("month"));
} catch {
  selectedMonth = normalizeSelectedMonth(null);
}
---

<Layout title="Family dashboard">
  <main class="bg-cosmic min-h-screen p-4 text-white sm:p-8">
    <div class="mx-auto w-full max-w-3xl rounded-2xl border border-white/10 bg-white/10 p-6 backdrop-blur-xl sm:p-8">
      <div
        class="mb-8 flex flex-col gap-3 border-b border-white/10 pb-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <div>
          <p class="text-sm text-blue-100/60">Signed in as {user?.email}</p>
          {successMessage && <p class="mt-1 text-sm text-emerald-300">{successMessage}</p>}
        </div>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="rounded-lg border border-white/20 px-4 py-2 text-sm hover:bg-white/10"
            >Sign out</button
          >
        </form>
      </div>

      {
        onboarding.kind === "no-family" ? (
          <div class="grid gap-8 md:grid-cols-2">
            <section>
              <p class="text-sm tracking-wide text-purple-200 uppercase">Start a shared space</p>
              <h1 class="mt-1 text-3xl font-bold">Create a family</h1>
              <p class="mt-2 text-blue-100/70">Name your family, then share its code with the other parent.</p>
              <div class="mt-6">
                <CreateFamilyForm serverError={error} client:load />
              </div>
            </section>
            <section class="border-t border-white/10 pt-8 md:border-t-0 md:border-l md:pt-0 md:pl-8">
              <p class="text-sm tracking-wide text-purple-200 uppercase">Have a code?</p>
              <h2 class="mt-1 text-2xl font-bold">Join a family</h2>
              <p class="mt-2 text-blue-100/70">Enter the code shared by the first parent.</p>
              <div class="mt-6">
                <JoinFamilyForm serverError={error} client:load />
              </div>
            </section>
          </div>
        ) : onboarding.kind === "creator-awaiting-parent" ? (
          <div class="space-y-8">
            <FamilySetupPanel
              familyName={onboarding.family.name}
              children={onboarding.family.children}
              joinCode={onboarding.joinCode}
              serverError={error}
            />
            <ExpenseWorkspace
              familyId={onboarding.family.id}
              userId={user.id}
              children={onboarding.family.children}
              month={selectedMonth}
              serverError={error}
            />
          </div>
        ) : (
          <div class="space-y-8">
            <FamilySummaryPanel familyName={onboarding.family.name} children={onboarding.family.children} />
            <ExpenseWorkspace
              familyId={onboarding.family.id}
              userId={user.id}
              children={onboarding.family.children}
              month={selectedMonth}
              serverError={error}
            />
          </div>
        )
      }
    </div>
  </main>
</Layout>
